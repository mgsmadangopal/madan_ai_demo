{
  "datasets": [
    {
      "name": "ds_generation",
      "displayName": "Daily Net Generation (Gold)",
      "queryLines": [
        "SELECT   settlement_day,   plant_id,   plant_name,   state,   region,   asset_type,   day_of_week,   CASE day_of_week     WHEN 1 THEN 'Mon'     WHEN 2 THEN 'Tue'     WHEN 3 THEN 'Wed'     WHEN 4 THEN 'Thu'     WHEN 5 THEN 'Fri'     WHEN 6 THEN 'Sat'     WHEN 7 THEN 'Sun'     ELSE 'Unknown'   END AS day_of_week_name,   net_mwh,   baseline_mwh,   (baseline_mwh - net_mwh) AS lost_mwh,   variance_mwh,   curtailment_window_minutes,   CAST(curtailment_flag_any AS STRING) AS curtailment_flag_any_str FROM main.madan_gopal.gold_daily_generation ORDER BY settlement_day "
      ]
    },
    {
      "name": "ds_generation_last30d_kpi",
      "displayName": "KPI Window: Generation Last 30 Days",
      "queryLines": [
        "WITH g AS (   SELECT     settlement_day,     plant_id,     plant_name,     state,     region,     asset_type,     net_mwh,     MAX(settlement_day) OVER () AS max_day   FROM main.madan_gopal.gold_daily_generation ), g30 AS (   SELECT     settlement_day,     plant_id,     plant_name,     state,     region,     asset_type,     net_mwh,     max_day   FROM g   WHERE settlement_day BETWEEN date_sub(max_day, 29) AND max_day ) SELECT   settlement_day,   plant_id,   plant_name,   state,   region,   asset_type,   net_mwh,   SUM(net_mwh) OVER () AS net_mwh_last_30d FROM g30 ORDER BY settlement_day "
      ]
    },
    {
      "name": "ds_revenue",
      "displayName": "Revenue Variance (Gold)",
      "queryLines": [
        "SELECT   settlement_day,   plant_id,   plant_name,   state,   region,   asset_type,   merchant_revenue_usd,   penalties_usd,   imbalance_charges_usd,   lost_revenue_usd,   total_variance_usd,   cumulative_impact_usd,   (lost_revenue_usd + penalties_usd + imbalance_charges_usd) AS impact_components_usd FROM main.madan_gopal.gold_revenue_variance ORDER BY settlement_day "
      ]
    },
    {
      "name": "ds_revenue_last30d_kpi",
      "displayName": "KPI Window: Revenue Impact Components Last 30 Days",
      "queryLines": [
        "WITH r AS (   SELECT     settlement_day,     plant_id,     plant_name,     state,     region,     asset_type,     (lost_revenue_usd + penalties_usd + imbalance_charges_usd) AS impact_components_usd,     MAX(settlement_day) OVER () AS max_day   FROM main.madan_gopal.gold_revenue_variance ), r30 AS (   SELECT     settlement_day,     plant_id,     plant_name,     state,     region,     asset_type,     impact_components_usd,     max_day   FROM r   WHERE settlement_day BETWEEN date_sub(max_day, 29) AND max_day ) SELECT   settlement_day,   plant_id,   plant_name,   state,   region,   asset_type,   impact_components_usd,   SUM(impact_components_usd) OVER () AS impact_usd_last_30d FROM r30 ORDER BY settlement_day "
      ]
    },
    {
      "name": "ds_om",
      "displayName": "O&M Costs (Gold)",
      "queryLines": [
        "SELECT   date,   plant_id,   plant_name,   state,   region,   asset_type,   equipment_type,   work_order_type,   vendor,   om_cost_usd,   labor_hours,   corrective_wo_count,   total_wo_count,   net_mwh,   cost_per_mwh_usd FROM main.madan_gopal.gold_om_costs ORDER BY date "
      ]
    },
    {
      "name": "ds_om_last30d_kpi",
      "displayName": "KPI Window: O&M Cost per MWh Last 30 Days",
      "queryLines": [
        "WITH o AS (   SELECT     date,     plant_id,     plant_name,     state,     region,     asset_type,     om_cost_usd,     net_mwh,     MAX(date) OVER () AS max_day   FROM main.madan_gopal.gold_om_costs ), o30 AS (   SELECT     date,     plant_id,     plant_name,     state,     region,     asset_type,     om_cost_usd,     net_mwh,     max_day   FROM o   WHERE date BETWEEN date_sub(max_day, 29) AND max_day ) SELECT   date,   plant_id,   plant_name,   state,   region,   asset_type,   om_cost_usd,   net_mwh,   (SUM(om_cost_usd) OVER () / NULLIF(SUM(net_mwh) OVER (), 0)) AS om_cost_per_mwh_last_30d FROM o30 ORDER BY date "
      ]
    },
    {
      "name": "ds_availability",
      "displayName": "Asset Availability (Gold)",
      "queryLines": [
        "SELECT   settlement_day,   plant_id,   plant_name,   state,   region,   asset_type,   equipment_type,   CASE     WHEN equipment_type = 'inverter' AND inverter_model IN ('XG-440','XG-360') THEN inverter_model     WHEN equipment_type = 'inverter' THEN 'Other'     ELSE 'Other'   END AS model_bucket,   inverter_model,   firmware_version,   availability_pct,   downtime_minutes,   trip_event_count,   derate_event_count FROM main.madan_gopal.gold_asset_availability ORDER BY settlement_day "
      ]
    },
    {
      "name": "ds_firmware_impact",
      "displayName": "Firmware Impact Evidence (Gold)",
      "queryLines": [
        "SELECT   plant_id,   plant_name,   state,   region,   asset_type,   settlement_day,   inverter_model,   firmware_version_mode,   vendor_ticket_count,   rollout_flag,   hotfix_flag,   net_mwh_variance_total,   availability_pct,   downtime_minutes,   top_alarm_code,   top_downtime_cause,   corrective_wo_count FROM main.madan_gopal.gold_firmware_impact ORDER BY settlement_day "
      ]
    }
  ],
